                                <td style="padding:0 12px;"><a href="https://tiktok.com/@easteam_official" target="_blank" style="text-decoration:none;"><img src="https://cdn.shopify.com/s/files/1/0853/2813/4440/files/tiktok_2.png?v=1779286908" alt="TikTok" width="24" height="24" style="display:block; width:24px; height:24px; border:0;" /></a></td>
